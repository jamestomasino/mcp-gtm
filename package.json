{
  "name": "mcp-gtm",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "MCP server for Google Tag Manager container JSON files. Zero auth, fully offline.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-gtm": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/1jehuang/mcp-gtm"
  },
  "homepage": "https://github.com/1jehuang/mcp-gtm#readme",
  "bugs": {
    "url": "https://github.com/1jehuang/mcp-gtm/issues"
  },
  "author": "Jcode",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "build:bundle": "node esbuild.config.mjs",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "npx @biomejs/biome check src/",
    "format": "npx @biomejs/biome format --write src/",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^22.10.2",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.9"
  },
  "keywords": [
    "mcp",
    "google-tag-manager",
    "gtm",
    "tag-manager",
    "model-context-protocol",
    "claude",
    "cursor",
    "llm"
  ],
  "license": "MIT",
  "files": [
    "dist/",
    "src/",
    "!dist/**/*.map",
    "biome.json"
  ]
}
